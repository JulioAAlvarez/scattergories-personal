generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Games {
  id     String  @id @default(uuid()) @db.Uuid
  roomId String?
  letter String?
  topic  String?
  answer String[]
}

model test {
  id   Int     @id @default(autoincrement())
  name String?
}
